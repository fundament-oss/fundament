{
  "name": "fundament-e2e",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "NODE_OPTIONS='--import tsx' cucumber-js",
    "test:headed": "HEADED=true NODE_OPTIONS='--import tsx' cucumber-js",
    "test:debug": "PWDEBUG=1 NODE_OPTIONS='--import tsx' cucumber-js",
    "test:tags": "NODE_OPTIONS='--import tsx' cucumber-js --tags",
    "test:api": "NODE_OPTIONS='--import tsx' cucumber-js --tags @api",
    "test:apikey": "NODE_OPTIONS='--import tsx' cucumber-js --tags @apikey",
    "test:token": "NODE_OPTIONS='--import tsx' cucumber-js --tags @token",
    "report": "open reports/cucumber-report.html"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.11.0",
    "@connectrpc/connect": "2.1.1",
    "@connectrpc/connect-node": "2.1.1"
  },
  "devDependencies": {
    "@cucumber/cucumber": "11.3.0",
    "@playwright/test": "1.58.0",
    "@types/node": "22.19.7",
    "dotenv": "16.6.1",
    "playwright": "1.58.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}

# Hetzner Cloud API token — create at:
#   Hetzner Cloud Console -> your Project -> Security -> API Tokens -> "Read & Write".
# Consumed by `just hetzner-up` / `hetzner-down` / `hetzner-ssh` / `hetzner-status`
# (exported as HCLOUD_TOKEN). The real secrets/hetzner.env is gitignored.
api_key=<replace-with-your-hetzner-cloud-api-token>

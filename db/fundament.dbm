		<type name="integer" length="0"/>
	</column>
	<column name="retry_after">
		<type name="timestamptz" length="0"/>
	</column>
	<column name="processed">
		<type name="timestamptz" length="0"/>
	</column>
	<column name="failed">
		<type name="timestamptz" length="0"/>
	</column>
	<column name="status_info">
		<type name="text" length="0"/>
	</column>

		<type name="uuid" length="0"/>
	</column>
	<column name="rack_id">
		<type name="uuid" length="0"/>
	</column>
	<column name="start_unit">
		<type name="integer" length="0"/>
	</column>
	<column name="slot_type">
		<type name="text" length="0"/>
	</column>
	<column name="parent_placement_id">
		<type name="uuid" length="0"/>
	</column>
	<column name="port_definition_id">
		<type name="uuid" length="0"/>
	</column>
	<column name="logical_device_id">
		<type name="uuid" length="0"/>
	</column>
	<column name="external_ref">
		<type name="text" length="0"/>
	</column>
	<column name="notes">
		<type name="text" length="0"/>
	</column>
	<column name="created" not-null="true" default-value="now()">
		<type name="timestamptz" length="0"/>
	</column>
	<column name="deleted">
		<type name="timestamptz" length="0"/>
	</column>
	<constraint name="placements_pk" type="pk-constr" table="dcim.placements">
		<columns names="id" ref-type="src-columns"/>
	</constraint>
	<constraint name="placements_ck_slot_type" type="ck-constr" table="dcim.placements">
			<expression> <![CDATA[slot_type IS NULL OR slot_type IN ('unit','power','zero_u')]]> </expression>
	</constraint>
	<constraint name="placements_ck_exclusive_arc" type="ck-constr" table="dcim.placements">
			<expression> <![CDATA[(rack_id IS NOT NULL AND slot_type IS NOT NULL AND parent_placement_id IS NULL AND port_definition_id IS NULL) OR (rack_id IS NULL AND start_unit IS NULL AND slot_type IS NULL AND parent_placement_id IS NOT NULL AND port_definition_id IS NOT NULL)]]> </expression>
	</constraint>
	<constraint name="placements_ck_unit_start" type="ck-constr" table="dcim.placements">
			<expression> <![CDATA[slot_type != 'unit' OR start_unit IS NOT NULL]]> </expression>
	</constraint>
</table>


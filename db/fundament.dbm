	<return-type>
	<type name="void" length="0"/>
	</return-type>
	<parameter name="p_id" in="true">
		<type name="uuid" length="0"/>
	</parameter>
	<definition> <![CDATA[BEGIN
	UPDATE authn.api_keys SET last_used = NOW() WHERE id = p_id;
END;]]> </definition>
</function>


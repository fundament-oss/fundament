# Hetzner Cloud API token — create at:
#   Hetzner Cloud Console -> your Project -> Security -> API Tokens -> "Read & Write".
# Consumed by `just hetzner-up` / `hetzner-down` / `hetzner-ssh` / `hetzner-status`
# (exported as HCLOUD_TOKEN). The real secrets/hetzner.env is gitignored.
api_key=<replace-with-your-hetzner-cloud-api-token>

# Optional: the SSH public key authorized to log into the box (the `fundament` user).
# Leave unset to default to your local ~/.ssh/id_ed25519.pub (else id_rsa.pub) — the
# same key hetzner.sh registers with hcloud. Only set this to use a different key than
# the one your ssh client presents (must be a key you hold, or `hetzner-ssh`/`stack`
# can't reach the box). Public, not secret — kept here just to co-locate box config.
# Quote the value — the key has spaces and this file is sourced by hetzner.sh.
#admin_pubkey="ssh-ed25519 AAAA... you@host"

# --- devbox role (just devbox …) ---------------------------------------------
# Per-dev box/volume naming: devbox-<name> / devbox-<name>-home.
# Defaults to your local username; set it if that isn't how you want the
# Hetzner resources named (also useful when sharing a project).
#devbox_name=<your-name>

# Optional: your dotfiles repo — cloned to ~/.dotfiles on the box on first
# bootstrap (install.sh is run if present and executable).
#devbox_dotfiles=https://github.com/you/dotfiles.git

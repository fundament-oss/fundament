{
  "name": "fundament-console",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "prebuild": "node generate-proto-version.js && bun build src/plugin-sdk/plugin-sdk.ts --outfile public/plugin-ui/plugin-sdk.js --target browser --minify && bun src/plugin-sdk/build-css.ts",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier --write ."
  },
  "packageManager": "bun@1.3.6",
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "plugins": [
      "prettier-plugin-tailwindcss"
    ],
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "21.1.1",
    "@angular/compiler": "21.1.1",
    "@angular/core": "21.2.4",
    "@angular/forms": "21.1.1",
    "@angular/platform-browser": "21.1.1",
    "@angular/router": "21.1.1",
    "@bufbuild/protobuf": "2.11.0",
    "@connectrpc/connect": "2.1.1",
    "@connectrpc/connect-web": "2.1.1",
    "@hey-api/client-fetch": "0.13.1",
    "@ng-icons/core": "33.0.0",
    "@ng-icons/tabler-icons": "33.0.0",
    "chart.js": "4.5.1",
    "js-yaml": "4.1.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "vanilla-calendar-pro": "3.1.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.1.0",
    "@angular/build": "21.1.2",
    "@angular/cli": "21.1.2",
    "@angular/compiler-cli": "21.1.1",
    "@bufbuild/buf": "1.64.0",
    "@bufbuild/protoc-gen-es": "2.11.0",
    "@connectrpc/protoc-gen-connect-es": "1.7.0",
    "@eslint/js": "9.39.2",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/postcss": "4.1.18",
    "@types/js-yaml": "4.0.9",
    "angular-eslint": "21.1.0",
    "bun-types": "1.3.9",
    "eslint": "9.39.2",
    "eslint-config-airbnb-extended": "3.0.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "jsdom": "27.4.0",
    "postcss": "8.5.6",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3",
    "typescript-eslint": "8.52.0",
    "vitest": "4.0.18"
  }
}

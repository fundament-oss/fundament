{
  "name": "fundament-console",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "prebuild": "node generate-proto-version.js && bun build src/plugin-sdk/plugin-sdk.ts --outfile public/plugin-ui/plugin-sdk.js --target browser --minify && bun src/plugin-sdk/build-css.ts",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier --write ."
  },
  "packageManager": "bun@1.3.13",
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "plugins": [
      "prettier-plugin-tailwindcss"
    ],
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "overrides": {
    "@bufbuild/protobuf": "2.11.0"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "21.2.9",
    "@angular/compiler": "21.2.9",
    "@angular/core": "21.2.9",
    "@angular/forms": "21.2.9",
    "@angular/platform-browser": "21.2.9",
    "@angular/router": "21.2.9",
    "@bufbuild/protobuf": "2.11.0",
    "@connectrpc/connect": "2.1.1",
    "@connectrpc/connect-web": "2.1.1",
    "@hey-api/client-fetch": "0.13.1",
    "@nldd/design-system": "^0.8.37",
    "chart.js": "4.5.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.3.1",
    "@angular/build": "21.2.7",
    "@angular/cli": "21.2.7",
    "@angular/compiler-cli": "21.2.9",
    "@bufbuild/buf": "1.68.3",
    "@bufbuild/protoc-gen-es": "2.11.0",
    "@connectrpc/protoc-gen-connect-es": "1.7.0",
    "@eslint/js": "10.0.1",
    "@tailwindcss/postcss": "4.2.3",
    "angular-eslint": "21.3.1",
    "eslint": "10.2.1",
    "eslint-config-airbnb-extended": "3.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.2.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "vitest": "4.1.4"
  }
}

---
import Layout from '../layouts/Landing.astro';
---

<Layout title="Fundament — Self-hosted Kubernetes platform">
  <section class="lp-hero">
    <div class="lp-hero-inner">
      <p class="lp-eyebrow">Self-hosted Kubernetes platform</p>
      <h1 class="lp-hero-title">Deploy and manage Kubernetes clusters with confidence.</h1>
      <p class="lp-hero-lede">
        Fundament is an open-source platform that combines bare-metal provisioning with managed
        Kubernetes, delivering a complete IaaS and PaaS solution for self-hosted infrastructure.
      </p>
      <div class="lp-btnrow">
        <nldd-button variant="accent-filled" href="/docs" text="Get started" end-icon="arrow-right">
        </nldd-button>
        <nldd-button
          variant="accent-outlined"
          href="https://github.com/fundament-oss/fundament"
          target="_blank"
          rel="nofollow noopener noreferrer"
          text="View on GitHub"
        >
          <svg
            slot="end-icon"
            class="h-5 w-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              clip-rule="evenodd"></path>
          </svg>
        </nldd-button>
      </div>

      <div class="lp-metastrip">
        <div class="lp-metastrip-cell">
          <p class="lp-metastrip-label">Model</p>
          <div class="lp-metastrip-value">Open source</div>
        </div>
        <div class="lp-metastrip-cell">
          <p class="lp-metastrip-label">Layer</p>
          <div class="lp-metastrip-value">IaaS + PaaS</div>
        </div>
        <div class="lp-metastrip-cell">
          <p class="lp-metastrip-label">Tenants</p>
          <div class="lp-metastrip-value">Thousands</div>
        </div>
        <div class="lp-metastrip-cell">
          <p class="lp-metastrip-label">Stance</p>
          <div class="lp-metastrip-value">Zero-trust</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <div class="lp-section">
    <div class="lp-section-head">
      <h2 class="lp-section-title">A complete cloud platform, self-hosted.</h2>
      <p class="lp-section-intro">
        Eight capabilities that define Fundament. No managed service required, no proprietary
        lock-in, no compromises on isolation.
      </p>
    </div>

    <div class="lp-caps overflow-hidden rounded-md">
      <div class="lp-cap">
        <div class="lp-cap-header">
          <span class="lp-cap-icon">
            <nldd-icon name="terminal" class="h-5.5 w-5.5"></nldd-icon>
          </span>
          <h3>Developer-friendly</h3>
        </div>
        <p>
          Simple, intuitive platform for deploying and operating applications without wrestling with
          infrastructure complexity.
        </p>
      </div>
      <div class="lp-cap">
        <div class="lp-cap-header">
          <span class="lp-cap-icon">
            <nldd-icon name="rectangle-stack" class="h-5.5 w-5.5"></nldd-icon>
          </span>
          <h3>Multi-tenant architecture</h3>
        </div>
        <p>
          Built for organizational growth with strict tenant isolation and shared-nothing compute
          and storage architecture.
        </p>
      </div>
      <div class="lp-cap">
        <div class="lp-cap-header">
          <span class="lp-cap-icon">
            <nldd-icon name="shield-check-mark" class="h-5.5 w-5.5"></nldd-icon>
          </span>
          <h3>Secure by default</h3>
        </div>
        <p>
          Security built into every layer with zero-trust principles and comprehensive isolation
          between tenants.
        </p>
      </div>
      <div class="lp-cap">
        <div class="lp-cap-header">
          <span class="lp-cap-icon">
            <nldd-icon name="cloud" class="h-5.5 w-5.5"></nldd-icon>
          </span>
          <h3>Managed infrastructure</h3>
        </div>
        <p>
          Compute, storage, and networking abstracted and managed, with automated bare-metal
          provisioning via metal-stack.
        </p>
      </div>
      <div class="lp-cap">
        <div class="lp-cap-header">
          <span class="lp-cap-icon">
            <nldd-icon name="check-mark-circle" class="h-5.5 w-5.5"></nldd-icon>
          </span>
          <h3>Highly available</h3>
        </div>
        <p>
          Designed to remain operational under heavy demand or failure conditions with built-in
          resilience.
        </p>
      </div>
      <div class="lp-cap">
        <div class="lp-cap-header">
          <span class="lp-cap-icon">
            <nldd-icon name="chart-x-y-axis-line" class="h-5.5 w-5.5"></nldd-icon>
          </span>
          <h3>Horizontally scalable</h3>
        </div>
        <p>
          Scale from a handful to thousands of tenants with large infrastructure footprints without
          architectural changes.
        </p>
      </div>
      <div class="lp-cap">
        <div class="lp-cap-header">
          <span class="lp-cap-icon">
            <nldd-icon name="puzzle-piece" class="h-5.5 w-5.5"></nldd-icon>
          </span>
          <h3>Extensible platform</h3>
        </div>
        <p>
          Pluggable services allow tenants to autonomously evolve and customize their technology
          stack.
        </p>
      </div>
      <div class="lp-cap">
        <div class="lp-cap-header">
          <span class="lp-cap-icon">
            <nldd-icon name="brackets-ellipsis" class="h-5.5 w-5.5"></nldd-icon>
          </span>
          <h3>Open source</h3>
        </div>
        <p>
          Built on proven open-source projects like metal-stack and Gardener, avoiding proprietary
          lock-in.
        </p>
      </div>
    </div>
  </div>

  <!-- Architecture -->
  <div class="lp-section">
    <div class="lp-section-head">
      <h2 class="lp-section-title">Built on proven foundations.</h2>
      <p class="lp-section-intro">
        Fundament combines best-in-class open-source technologies to deliver a complete cloud
        solution.
      </p>
    </div>

    <div class="lp-arch rounded-md">
      <div class="lp-arch-piece">
        <span class="lp-arch-layer">IaaS layer</span>
        <h3 class="lp-arch-name">metal-stack</h3>
        <p class="lp-arch-desc">
          Automated bare-metal provisioning for reliable, high-performance infrastructure.
        </p>
      </div>
      <div class="lp-arch-op" aria-hidden="true">+</div>
      <div class="lp-arch-piece">
        <span class="lp-arch-layer">Orchestration</span>
        <h3 class="lp-arch-name">Gardener</h3>
        <p class="lp-arch-desc">Enterprise-grade Kubernetes cluster management at scale.</p>
      </div>
      <div class="lp-arch-op" aria-hidden="true">=</div>
      <div class="lp-arch-piece lp-arch-piece--final">
        <span class="lp-arch-layer">Complete solution</span>
        <h3 class="lp-arch-name">Fundament</h3>
        <p class="lp-arch-desc">IaaS + PaaS for self-hosted infrastructure.</p>
      </div>
    </div>
  </div>

  <!-- End CTA -->
  <section class="lp-endcta">
    <div class="lp-endcta-inner">
      <div>
        <h2>Ready to get started?</h2>
        <p>Deploy Fundament in your infrastructure and start managing Kubernetes clusters today.</p>
      </div>
      <div class="lp-btnrow">
        <nldd-button
          variant="accent-filled"
          href="/docs"
          text="Read the documentation"
          start-icon="file-text"></nldd-button>
        <nldd-button
          variant="accent-outlined"
          text="Explore on GitHub"
          href="https://github.com/fundament-oss/fundament"
          target="_blank"
          rel="nofollow noopener noreferrer"
        >
          <svg
            slot="start-icon"
            class="h-5 w-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              clip-rule="evenodd"></path>
          </svg>
        </nldd-button>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  @reference "tailwindcss";

  @theme {
    --color-accent-25: oklch(0.973 0.013 253.4);
    --color-accent-50: oklch(0.947 0.026 253.4);
    --color-accent-75: oklch(0.922 0.038 253.4);
    --color-accent-100: oklch(0.897 0.051 253.4);
    --color-accent-150: oklch(0.849 0.076 253.4);
    --color-accent-200: oklch(0.804 0.097 253.4);
    --color-accent-250: oklch(0.76 0.097 253.4);
    --color-accent-300: oklch(0.718 0.097 253.4);
    --color-accent-350: oklch(0.677 0.097 253.4);
    --color-accent-400: oklch(0.638 0.097 253.4);
    --color-accent-450: oklch(0.6 0.097 253.4);
    --color-accent-500: oklch(0.563 0.097 253.4);
    --color-accent-550: oklch(0.527 0.097 253.4);
    --color-accent-600: oklch(0.492 0.097 253.4);
    --color-accent-650: oklch(0.457 0.097 253.4);
    --color-accent-700: oklch(0.421 0.097 253.4);
    --color-accent-750: oklch(0.386 0.097 253.4);
    --color-accent-800: oklch(0.348 0.097 253.4);
    --color-accent-850: oklch(0.308 0.096 253.4);
    --color-accent-900: oklch(0.262 0.082 253.4);
    --color-accent-950: oklch(0.203 0.063 253.4);

    --color-neutral-25: oklch(0.974 0.004 253.4);
    --color-neutral-50: oklch(0.948 0.007 253.4);
    --color-neutral-75: oklch(0.923 0.009 253.4);
    --color-neutral-100: oklch(0.898 0.011 253.4);
    --color-neutral-150: oklch(0.85 0.015 253.4);
    --color-neutral-200: oklch(0.804 0.019 253.4);
    --color-neutral-250: oklch(0.76 0.023 253.4);
    --color-neutral-300: oklch(0.718 0.026 253.4);
    --color-neutral-350: oklch(0.677 0.03 253.4);
    --color-neutral-400: oklch(0.638 0.033 253.4);
    --color-neutral-450: oklch(0.6 0.037 253.4);
    --color-neutral-500: oklch(0.563 0.04 253.4);
    --color-neutral-550: oklch(0.527 0.036 253.4);
    --color-neutral-600: oklch(0.491 0.032 253.4);
    --color-neutral-650: oklch(0.456 0.029 253.4);
    --color-neutral-700: oklch(0.421 0.026 253.4);
    --color-neutral-750: oklch(0.385 0.023 253.4);
    --color-neutral-800: oklch(0.347 0.02 253.4);
    --color-neutral-850: oklch(0.307 0.018 253.4);
    --color-neutral-900: oklch(0.261 0.015 253.4);
    --color-neutral-950: oklch(0.202 0.011 253.4);

    --color-danger-25: oklch(0.975 0.012 29.5);
    --color-danger-50: oklch(0.951 0.025 29.5);
    --color-danger-75: oklch(0.927 0.037 29.5);
    --color-danger-100: oklch(0.903 0.05 29.5);
    --color-danger-150: oklch(0.859 0.077 29.5);
    --color-danger-200: oklch(0.816 0.104 29.5);
    --color-danger-250: oklch(0.776 0.132 29.5);
    --color-danger-300: oklch(0.737 0.161 29.5);
    --color-danger-350: oklch(0.7 0.191 29.5);
    --color-danger-400: oklch(0.663 0.207 29.5);
    --color-danger-450: oklch(0.625 0.207 29.5);
    --color-danger-500: oklch(0.588 0.207 29.5);
    --color-danger-550: oklch(0.552 0.207 29.5);
    --color-danger-600: oklch(0.517 0.207 29.5);
    --color-danger-650: oklch(0.48 0.195 29.5);
    --color-danger-700: oklch(0.443 0.18 29.5);
    --color-danger-750: oklch(0.405 0.165 29.5);
    --color-danger-800: oklch(0.365 0.148 29.5);
    --color-danger-850: oklch(0.323 0.131 29.5);
    --color-danger-900: oklch(0.275 0.112 29.5);
    --color-danger-950: oklch(0.212 0.086 29.5);
  }

  /* Hero */
  .lp-hero {
    border-bottom: 1px solid var(--semantics-dividers-color);
    background: var(--semantics-surfaces-background-color);
  }
  .lp-hero-inner {
    @apply mx-auto max-w-7xl;
    padding: var(--primitives-space-80) var(--primitives-space-32) var(--primitives-space-64);
  }
  .lp-eyebrow {
    font: var(--primitives-font-body-sm-bold-snug);
    @apply flex items-center tracking-[0.08em] uppercase;
    color: var(--semantics-content-secondary-color);
    margin: 0 0 var(--primitives-space-16);
    gap: var(--primitives-space-10);
  }
  .lp-hero-title {
    font: var(--primitives-font-display-1-lg);
    margin: 0 0 var(--primitives-space-24);
    @apply max-w-225 tracking-[-0.02em];
    color: var(--semantics-content-color);
  }
  .lp-hero-lede {
    font: var(--primitives-font-body-lg-regular-snug);
    @apply max-w-180;
    color: var(--semantics-content-color);
    margin: 0 0 var(--primitives-space-32);
  }

  /* Buttons */
  .lp-btnrow {
    @apply flex flex-wrap;
    gap: var(--primitives-space-12);
  }

  /* Metastrip */
  .lp-metastrip {
    @apply grid grid-cols-4 gap-0;
    border-top: 1px solid var(--semantics-dividers-color);
    margin-top: var(--primitives-space-56);
    padding-top: var(--primitives-space-24);
  }
  .lp-metastrip-cell {
    padding-right: var(--primitives-space-24);
  }
  .lp-metastrip-cell + .lp-metastrip-cell {
    border-left: 1px solid var(--semantics-dividers-color);
    padding-left: var(--primitives-space-24);
  }
  .lp-metastrip-label {
    font: var(--primitives-font-body-xs-regular-snug);
    @apply tracking-[0.06em] uppercase;
    color: var(--semantics-content-secondary-color);
    margin: 0 0 var(--primitives-space-6);
  }
  .lp-metastrip-value {
    font: var(--primitives-font-display-5-lg);
    @apply font-normal tracking-[-0.01em];
    color: var(--semantics-content-color);
  }

  /* Sections */
  .lp-section {
    @apply mx-auto max-w-7xl;
    padding: var(--primitives-space-80) var(--primitives-space-32);
  }
  .lp-section:not(:first-of-type) {
    border-top: 1px solid var(--semantics-dividers-color);
  }
  .lp-section-head {
    @apply grid grid-cols-[1fr_2fr] items-start;
    gap: var(--primitives-space-48);
    margin-bottom: var(--primitives-space-48);
  }
  .lp-section-kicker {
    font: var(--primitives-font-body-sm-bold-snug);
    color: var(--semantics-content-secondary-color);
    @apply mx-0 mt-1.5 mb-0 tracking-[0.08em] uppercase;
  }
  .lp-section-title {
    font: var(--primitives-font-display-3-lg);
    margin: 0 0 var(--primitives-space-16);
    @apply tracking-[-0.015em];
    color: var(--semantics-content-color);
  }
  .lp-section-intro {
    font: var(--primitives-font-body-md-regular-snug);
    color: var(--semantics-content-color);
    @apply m-0 max-w-160;
  }

  /* Capabilities grid */
  .lp-caps {
    @apply grid grid-cols-3;
    border-top: 1px solid var(--semantics-dividers-color);
    border-left: 1px solid var(--semantics-dividers-color);
  }
  .lp-cap {
    border-right: 1px solid var(--semantics-dividers-color);
    border-bottom: 1px solid var(--semantics-dividers-color);
    padding: var(--primitives-space-28);
    @apply flex min-h-55 flex-col;
    gap: var(--primitives-space-16);
  }
  .lp-cap-header {
    @apply flex items-center;
    gap: var(--primitives-space-12);
  }
  .lp-cap-icon {
    @apply inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-sm;
    background: var(--primitives-color-accent-100);
    color: var(--primitives-color-accent-700);
  }
  .lp-cap h3 {
    font: var(--primitives-font-body-lg-bold-snug);
    @apply m-0 tracking-[-0.005em];
    color: var(--semantics-content-color);
  }
  .lp-cap p {
    font: var(--primitives-font-body-sm-regular-snug);
    color: var(--semantics-content-secondary-color);
    @apply m-0;
  }

  /* Architecture equation */
  .lp-arch {
    background: var(--semantics-surfaces-tinted-background-color);
    padding: var(--primitives-space-48);
    @apply grid grid-cols-[1fr_auto_1fr_auto_1fr] items-center;
    gap: var(--primitives-space-32);
  }
  .lp-arch-piece {
    @apply flex flex-col;
    gap: var(--primitives-space-8);
  }
  .lp-arch-layer {
    font: var(--primitives-font-body-xs-regular-snug);
    @apply tracking-widest uppercase;
    color: var(--semantics-content-secondary-color);
  }
  .lp-arch-name {
    font: var(--primitives-font-display-4-lg);
    @apply m-0 tracking-[-0.01em];
    color: var(--semantics-content-color);
  }
  .lp-arch-desc {
    font: var(--primitives-font-body-sm-regular-snug);
    color: var(--semantics-content-color);
    @apply m-0;
  }
  .lp-arch-op {
    font-family: var(--primitives-font-family-monospace);
    @apply text-center text-[32px] font-normal no-underline;
    color: var(--primitives-color-accent-600);
  }
  .lp-arch-piece--final .lp-arch-name {
    color: var(--primitives-color-accent-600);
  }

  /* End CTA */
  .lp-endcta {
    border-top: 1px solid var(--semantics-dividers-color);
    background: var(--semantics-surfaces-tinted-background-color);
  }
  .lp-endcta-inner {
    @apply mx-auto grid max-w-7xl grid-cols-[1fr_auto] items-center;
    padding: var(--primitives-space-64) var(--primitives-space-32);
    gap: var(--primitives-space-32);
  }
  .lp-endcta h2 {
    font: var(--primitives-font-display-3-lg);
    margin: 0 0 var(--primitives-space-8);
    @apply tracking-[-0.015em];
    color: var(--semantics-content-color);
  }
  .lp-endcta p {
    font: var(--primitives-font-body-md-regular-snug);
    color: var(--semantics-content-color);
    @apply m-0 max-w-160;
  }

  /* Responsive */
  @media (max-width: 1000px) {
    .lp-caps {
      @apply grid-cols-2;
    }
  }
  @media (max-width: 900px) {
    .lp-section-head,
    .lp-endcta-inner {
      @apply grid-cols-1;
    }
    .lp-caps {
      @apply grid-cols-1;
    }
    .lp-arch {
      @apply grid-cols-1;
    }
    .lp-metastrip {
      @apply grid-cols-2;
    }
  }
</style>

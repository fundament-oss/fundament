---
import Layout from '../layouts/Landing.astro';
---

<Layout title="Fundament — Self-hosted Kubernetes platform">
  <section class="lp-hero">
    <p class="lp-eyebrow">Self-hosted Kubernetes platform</p>
    <h1 class="lp-hero-title">Deploy and manage Kubernetes clusters with confidence.</h1>
    <p class="lp-hero-lede">
      Fundament is an open-source platform that combines bare-metal provisioning with managed
      Kubernetes, delivering a complete IaaS and PaaS solution for self-hosted infrastructure.
    </p>
    <div class="lp-btnrow">
      <nldd-button variant="primary" href="/docs" text="Get started" end-icon="arrow-right">
      </nldd-button>
      <nldd-button
        variant="accent-outlined"
        href="https://github.com/fundament-oss/fundament"
        target="_blank"
        rel="nofollow noopener noreferrer"
        text="View on GitHub"
      >
        <svg
          slot="end-icon"
          class="h-5 w-5"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
            clip-rule="evenodd"></path>
        </svg>
      </nldd-button>
    </div>

    <div class="lp-metastrip">
      <div class="lp-metastrip-cell">
        <p class="lp-metastrip-label">Model</p>
        <div class="lp-metastrip-value">Open source</div>
      </div>
      <div class="lp-metastrip-cell">
        <p class="lp-metastrip-label">Layer</p>
        <div class="lp-metastrip-value">IaaS + PaaS</div>
      </div>
      <div class="lp-metastrip-cell">
        <p class="lp-metastrip-label">Tenants</p>
        <div class="lp-metastrip-value">Thousands</div>
      </div>
      <div class="lp-metastrip-cell">
        <p class="lp-metastrip-label">Stance</p>
        <div class="lp-metastrip-value">Zero-trust</div>
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <div class="lp-section">
    <div class="lp-section-head">
      <h2 class="lp-section-title">A complete cloud platform, self-hosted.</h2>
      <p class="lp-section-intro">
        Eight capabilities that define Fundament. No managed service required, no proprietary
        lock-in, no compromises on isolation.
      </p>
    </div>

    <div class="lp-caps overflow-hidden rounded-md">
      <div class="lp-cap">
        <div class="lp-cap-header">
          <span class="lp-cap-icon">
            <nldd-icon name="terminal" class="h-5.5 w-5.5"></nldd-icon>
          </span>
          <h3>Developer-friendly</h3>
        </div>
        <p>
          Simple, intuitive platform for deploying and operating applications without wrestling with
          infrastructure complexity.
        </p>
      </div>
      <div class="lp-cap">
        <div class="lp-cap-header">
          <span class="lp-cap-icon">
            <nldd-icon name="rectangle-stack" class="h-5.5 w-5.5"></nldd-icon>
          </span>
          <h3>Multi-tenant architecture</h3>
        </div>
        <p>
          Built for organizational growth with strict tenant isolation and shared-nothing compute
          and storage architecture.
        </p>
      </div>
      <div class="lp-cap">
        <div class="lp-cap-header">
          <span class="lp-cap-icon">
            <nldd-icon name="shield-check-mark" class="h-5.5 w-5.5"></nldd-icon>
          </span>
          <h3>Secure by default</h3>
        </div>
        <p>
          Security built into every layer with zero-trust principles and comprehensive isolation
          between tenants.
        </p>
      </div>
      <div class="lp-cap">
        <div class="lp-cap-header">
          <span class="lp-cap-icon">
            <nldd-icon name="cloud" class="h-5.5 w-5.5"></nldd-icon>
          </span>
          <h3>Managed infrastructure</h3>
        </div>
        <p>
          Compute, storage, and networking abstracted and managed, with automated bare-metal
          provisioning via metal-stack.
        </p>
      </div>
      <div class="lp-cap">
        <div class="lp-cap-header">
          <span class="lp-cap-icon">
            <nldd-icon name="check-mark-circle" class="h-5.5 w-5.5"></nldd-icon>
          </span>
          <h3>Highly available</h3>
        </div>
        <p>
          Designed to remain operational under heavy demand or failure conditions with built-in
          resilience.
        </p>
      </div>
      <div class="lp-cap">
        <div class="lp-cap-header">
          <span class="lp-cap-icon">
            <nldd-icon name="chart-x-y-axis-line" class="h-5.5 w-5.5"></nldd-icon>
          </span>
          <h3>Horizontally scalable</h3>
        </div>
        <p>
          Scale from a handful to thousands of tenants with large infrastructure footprints without
          architectural changes.
        </p>
      </div>
      <div class="lp-cap">
        <div class="lp-cap-header">
          <span class="lp-cap-icon">
            <nldd-icon name="puzzle-piece" class="h-5.5 w-5.5"></nldd-icon>
          </span>
          <h3>Extensible platform</h3>
        </div>
        <p>
          Pluggable services allow tenants to autonomously evolve and customize their technology
          stack.
        </p>
      </div>
      <div class="lp-cap">
        <div class="lp-cap-header">
          <span class="lp-cap-icon">
            <nldd-icon name="brackets-ellipsis" class="h-5.5 w-5.5"></nldd-icon>
          </span>
          <h3>Open source</h3>
        </div>
        <p>
          Built on proven open-source projects like metal-stack and Gardener, avoiding proprietary
          lock-in.
        </p>
      </div>
    </div>
  </div>

  <!-- Architecture -->
  <div class="lp-section">
    <div class="lp-section-head">
      <h2 class="lp-section-title">Built on proven foundations.</h2>
      <p class="lp-section-intro">
        Fundament combines best-in-class open-source technologies to deliver a complete cloud
        solution.
      </p>
    </div>

    <div class="lp-arch rounded-md">
      <div class="lp-arch-piece">
        <span class="lp-arch-layer">IaaS layer</span>
        <h3 class="lp-arch-name">metal-stack</h3>
        <p class="lp-arch-desc">
          Automated bare-metal provisioning for reliable, high-performance infrastructure.
        </p>
      </div>
      <div class="lp-arch-op" aria-hidden="true">+</div>
      <div class="lp-arch-piece">
        <span class="lp-arch-layer">Orchestration</span>
        <h3 class="lp-arch-name">Gardener</h3>
        <p class="lp-arch-desc">Enterprise-grade Kubernetes cluster management at scale.</p>
      </div>
      <div class="lp-arch-op" aria-hidden="true">=</div>
      <div class="lp-arch-piece lp-arch-piece--final">
        <span class="lp-arch-layer">Complete solution</span>
        <h3 class="lp-arch-name">Fundament</h3>
        <p class="lp-arch-desc">IaaS + PaaS for self-hosted infrastructure.</p>
      </div>
    </div>
  </div>

  <!-- End CTA -->
  <section class="lp-endcta">
    <div class="lp-endcta-inner">
      <div>
        <h2>Ready to get started?</h2>
        <p>Deploy Fundament in your infrastructure and start managing Kubernetes clusters today.</p>
      </div>
      <div class="lp-btnrow">
        <nldd-button
          variant="primary"
          href="/docs"
          text="Read the documentation"
          start-icon="file-text"></nldd-button>
        <nldd-button
          variant="accent-outlined"
          text="Explore on GitHub"
          href="https://github.com/fundament-oss/fundament"
          target="_blank"
          rel="nofollow noopener noreferrer"
        >
          <svg
            slot="start-icon"
            class="h-5 w-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              clip-rule="evenodd"></path>
          </svg>
        </nldd-button>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  @reference "../styles/global.css";

  /* Hero */
  .lp-hero {
    @apply pt-primitives-space-80 px-primitives-space-32 pb-primitives-space-64 mx-auto max-w-7xl;
  }
  .lp-eyebrow {
    @apply text-body-sm font-body text-content-secondary mb-primitives-space-16 gap-primitives-space-10 m-0 flex items-center font-medium tracking-[0.08em] uppercase;
  }
  .lp-hero-title {
    @apply text-display-1 font-display mb-primitives-space-24 text-content m-0 max-w-225 font-medium tracking-[-0.02em];
  }
  .lp-hero-lede {
    @apply text-body-lg font-body text-content mb-primitives-space-32 m-0 max-w-180 font-normal;
  }

  /* Buttons */
  .lp-btnrow {
    @apply gap-primitives-space-12 flex flex-wrap;
  }

  /* Metastrip */
  .lp-metastrip {
    @apply border-dividers mt-primitives-space-56 pt-primitives-space-24 grid grid-cols-4 gap-0 border-t;
  }
  .lp-metastrip-cell {
    @apply pr-primitives-space-24;
  }
  .lp-metastrip-cell + .lp-metastrip-cell {
    @apply border-dividers pl-primitives-space-24 border-l;
  }
  .lp-metastrip-label {
    @apply text-body-xs font-body text-content-secondary mb-primitives-space-6 m-0 font-normal tracking-[0.06em] uppercase;
  }
  .lp-metastrip-value {
    @apply text-display-5 font-display text-content font-normal tracking-[-0.01em];
  }

  /* Sections */
  .lp-section {
    @apply py-primitives-space-80 px-primitives-space-32 mx-auto max-w-7xl;
  }
  .lp-section-head {
    @apply gap-primitives-space-48 mb-primitives-space-48 grid grid-cols-[1fr_2fr] items-start;
  }
  .lp-section-title {
    @apply text-display-3 font-display mb-primitives-space-16 text-content m-0 font-medium tracking-[-0.015em];
  }
  .lp-section-intro {
    @apply text-body-md font-body text-content m-0 max-w-160 font-normal;
  }

  /* Capabilities grid */
  .lp-caps {
    @apply border-dividers grid grid-cols-3 border-t border-l;
  }
  .lp-cap {
    @apply border-dividers p-primitives-space-28 gap-primitives-space-16 flex min-h-55 flex-col border-r border-b;
  }
  .lp-cap-header {
    @apply gap-primitives-space-12 flex items-center;
  }
  .lp-cap-icon {
    @apply bg-accent-100 text-accent-700 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-sm;
  }
  .lp-cap h3 {
    @apply text-body-lg font-body text-content m-0 font-medium tracking-[-0.005em];
  }
  .lp-cap p {
    @apply text-body-sm font-body text-content-secondary m-0 font-normal;
  }

  /* Architecture equation */
  .lp-arch {
    @apply bg-surface-tinted p-primitives-space-48 gap-primitives-space-32 grid grid-cols-[1fr_auto_1fr_auto_1fr] items-center;
  }
  .lp-arch-piece {
    @apply gap-primitives-space-8 flex flex-col;
  }
  .lp-arch-layer {
    @apply text-body-xs font-body text-content-secondary font-normal tracking-widest uppercase;
  }
  .lp-arch-name {
    @apply text-display-4 font-display text-content m-0 font-medium tracking-[-0.01em];
  }
  .lp-arch-desc {
    @apply text-body-sm font-body text-content m-0 font-normal;
  }
  .lp-arch-op {
    @apply text-accent-600 text-center font-mono text-[32px] font-normal no-underline;
  }
  .lp-arch-piece--final .lp-arch-name {
    @apply text-accent-600;
  }

  /* End CTA */
  .lp-endcta {
    @apply border-dividers bg-surface-tinted border-t;
  }
  .lp-endcta-inner {
    @apply py-primitives-space-64 px-primitives-space-32 gap-primitives-space-32 mx-auto grid max-w-7xl grid-cols-[1fr_auto] items-center;
  }
  .lp-endcta h2 {
    @apply text-display-3 font-display mb-primitives-space-8 text-content m-0 font-medium tracking-[-0.015em];
  }
  .lp-endcta p {
    @apply text-body-md font-body text-content m-0 max-w-160 font-normal;
  }

  /* Responsive */
  @media (max-width: 1000px) {
    .lp-caps {
      @apply grid-cols-2;
    }
  }
  @media (max-width: 900px) {
    .lp-section-head,
    .lp-endcta-inner {
      @apply grid-cols-1;
    }
    .lp-caps {
      @apply grid-cols-1;
    }
    .lp-arch {
      @apply grid-cols-1;
    }
    .lp-metastrip {
      @apply grid-cols-2;
    }
  }
</style>

---
import '../styles/nldd-settings.css';
import '../styles/global.css';

export interface Props {
  title?: string;
}

const { title = 'Fundament' } = Astro.props;

const { pathname } = Astro.url;
const isActive = (path: string) => pathname === path || pathname === `${path}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Fundament - Open-source platform for deploying and managing Kubernetes clusters with bare-metal provisioning"
    />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/img/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/img/favicon.svg" />
    <link rel="shortcut icon" href="/img/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <header class="topbar">
      <div class="topbar__inner">
        <a href="/" class="wordmark">
          <span class="wordmark__logo text-indigo-600 dark:text-indigo-400" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path
                fill="currentColor"
                d="M6 5h12a1 1 0 0 1 1 1a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1a1 1 0 0 1 1-1m15-3v2H3V2zm-6 6h2v14h-2zM7 8h2v14H7zm4 0h2v14h-2z"
              ></path>
            </svg>
          </span>
          Fundament
        </a>
        <nav class="topnav" aria-label="Primary">
          <a href="/" aria-current={isActive('/') ? 'page' : undefined}>Home</a>
          <a href="/about" aria-current={isActive('/about') ? 'page' : undefined}>About</a>
          <a href="/docs" aria-current={isActive('/docs') ? 'page' : undefined}>Docs</a>
        </nav>
        <div class="topbar__spacer"></div>
        <button id="theme-toggle" class="iconbtn" aria-label="Toggle theme" type="button">
          <svg
            id="theme-icon-moon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="18"
            height="18"
          >
            <path
              fill="currentColor"
              d="M10.47 2.12a8.99 8.99 0 0 0 11.41 11.4 10 10 0 1 1-11.4-11.4M8 5.07A8 8 0 1 0 18.93 16 11 11 0 0 1 8 5.07"
            ></path>
          </svg>
          <svg
            id="theme-icon-sun"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="18"
            height="18"
            style="display:none"
          >
            <path
              fill="currentColor"
              d="M13 22h-2v-3.07c.65.09 1.35.09 2 0zM6.4 16.2q.6.8 1.4 1.4l-2.16 2.18-1.42-1.42zM19.78 18.36l-1.42 1.42-2.17-2.17q.8-.6 1.42-1.42z"
            ></path>
            <path
              fill="currentColor"
              d="M12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10m0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6"></path>
            <path
              fill="currentColor"
              d="M5.07 11c-.1.65-.1 1.35 0 2H2v-2zM22 13h-3.07c.1-.65.1-1.35 0-2H22zM7.8 6.4Q7 7 6.4 7.8L4.21 5.65l1.42-1.42zM19.78 5.64 17.6 7.8a7 7 0 0 0-1.42-1.42l2.17-2.17zM13 5.07c-.65-.1-1.35-.1-2 0V2h2z"
            ></path>
          </svg>
        </button>
        <a
          href="https://github.com/fundament-oss/fundament"
          class="iconbtn -ml-5.5"
          target="_blank"
          rel="nofollow noopener noreferrer"
          aria-label="GitHub repository"
        >
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
      </div>
    </header>

    <slot />

    <footer class="foot">
      <div class="foot__inner">
        <span class="wordmark" style="cursor:default;">
          <span class="wordmark__logo" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path
                fill="currentColor"
                d="M6 5h12a1 1 0 0 1 1 1a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1a1 1 0 0 1 1-1m15-3v2H3V2zm-6 6h2v14h-2zM7 8h2v14H7zm4 0h2v14h-2z"
              ></path>
            </svg>
          </span>
          Fundament
        </span>
        <div class="foot__links">
          <a href="https://digilab.overheid.nl/" target="_blank">Digilab</a>
          <a
            href="https://github.com/fundament-oss/fundament"
            target="_blank"
            rel="nofollow noopener noreferrer">GitHub</a
          >
        </div>
        <div class="foot__meta">Open source · Apache 2.0</div>
      </div>
    </footer>
  </body>
</html>

<script is:inline>
  /* eslint-disable */
  (function () {
    var htmlEl = document.documentElement;

    function apply(isDark) {
      htmlEl.dataset.scheme = isDark ? 'dark' : 'light';
      htmlEl.classList.toggle('dark', isDark);

      var moon = document.getElementById('theme-icon-moon');
      var sun = document.getElementById('theme-icon-sun');
      if (moon) moon.style.display = isDark ? 'none' : '';
      if (sun) sun.style.display = isDark ? '' : 'none';
    }

    var saved = localStorage.getItem('starlight-theme') || localStorage.getItem('fnd-scheme');
    var isDark =
      saved === 'dark'
        ? true
        : saved === 'light'
          ? false
          : window.matchMedia('(prefers-color-scheme: dark)').matches;

    apply(isDark);

    document.getElementById('theme-toggle')?.addEventListener('click', function () {
      isDark = !isDark;
      localStorage.setItem('starlight-theme', isDark ? 'dark' : 'light');
      localStorage.setItem('fnd-scheme', isDark ? 'dark' : 'light');
      if (document.startViewTransition) {
        document.startViewTransition(function () {
          apply(isDark);
        });
      } else {
        apply(isDark);
      }
    });
  })();
</script>

<style is:global>
  @reference "tailwindcss/theme";

  body {
    font: var(--primitives-font-body-md-regular-snug);
    color: var(--semantics-content-color);
    background: var(--semantics-surfaces-background-color);
    -webkit-font-smoothing: antialiased;
    margin: 0;
  }

  *:focus-visible {
    outline: var(--semantics-focus-ring-outline);
    box-shadow: var(--semantics-focus-ring-box-shadow);
  }

  a {
    color: var(--semantics-links-color);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  a:hover {
    color: var(--semantics-links-is-hovered-color);
  }

  /* Top bar */
  .topbar {
    border-bottom: 1px solid var(--semantics-dividers-color);
    background: var(--semantics-surfaces-background-color);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .topbar__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--primitives-space-32);
    display: flex;
    align-items: center;
    gap: var(--primitives-space-32);
    height: 64px;
  }
  .wordmark {
    font: var(--primitives-font-body-lg-bold-tight);
    color: var(--semantics-content-color);
    text-decoration: none;
    letter-spacing: -0.01em;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .wordmark:hover {
    color: var(--semantics-content-color);
  }
  .wordmark__logo {
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .wordmark__logo svg {
    width: 100%;
    height: 100%;
  }

  .topnav {
    display: flex;
    gap: var(--primitives-space-24);
    margin-left: var(--primitives-space-16);
  }
  .topnav a {
    font: var(--primitives-font-body-md-regular-snug);
    color: var(--semantics-content-color);
    text-decoration: none;
    padding: 4px 0;
  }
  .topnav a[aria-current='page'] {
    font-weight: 500;
    border-bottom: 2px solid var(--primitives-color-accent-600);
  }
  .topnav a:hover {
    color: var(--semantics-links-is-hovered-color);
  }
  .topbar__spacer {
    flex: 1;
  }
  .iconbtn {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--semantics-dividers-color);
    color: var(--semantics-content-color);
    cursor: pointer;
    border-radius: var(--semantics-controls-sm-corner-radius);
    text-decoration: none;
  }
  .iconbtn:hover {
    background: var(--semantics-surfaces-tinted-background-color);
    color: var(--semantics-content-color);
  }

  /* Footer */
  .foot {
    border-top: 1px solid var(--semantics-dividers-color);
  }
  .foot__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: var(--primitives-space-32);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--primitives-space-24);
  }
  .foot__links {
    display: flex;
    gap: var(--primitives-space-24);
    font: var(--primitives-font-body-sm-regular-snug);
  }
  .foot__meta {
    font: var(--primitives-font-body-sm-regular-snug);
    color: var(--semantics-content-secondary-color);
  }
</style>

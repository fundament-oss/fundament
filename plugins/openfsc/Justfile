kube_context := env("kube_context", "k3d-fundament-plugin")
registry_port := "5112"

# `just plugin-install openfsc` turns the recorded ref into
# PluginInstallation.spec.config (→ FUNP_OPERATOR_IMAGE), so run this first to
# deploy the locally-built operator instead of the published image.

# Build and push the openfsc-operator image for the sandbox cluster
operator-push:
    #!/usr/bin/env bash
    set -euo pipefail
    tag=$(git describe --always --dirty)
    image="localhost:{{ registry_port }}/openfsc-operator:${tag}"
    docker build -t "${image}" -f ../../openfsc-operator/Dockerfile ../..
    docker push "${image}"
    echo "OPERATOR_IMAGE=${image}" > .sandbox-config
    echo "wrote .sandbox-config: OPERATOR_IMAGE=${image}"

# Prereqs: `just openfsc::operator-push`, then `just plugin-install openfsc`.

# Verify the OpenFSC install: PluginInstallation Running + sample FSCInstallation Active
test:
    #!/usr/bin/env bash
    set -euo pipefail
    k="kubectl --context {{ kube_context }}"
    echo "Waiting for PluginInstallation/openfsc to be Running (first install pulls many images)..."
    $k wait --for=jsonpath='{.status.phase}'=Running plugininstallation/openfsc --timeout=900s
    echo "Creating the fsc-demo namespace and the sample FSCInstallation..."
    $k create namespace fsc-demo --dry-run=client -o yaml | $k apply -f -
    $k apply -f ../../openfsc-operator/config/samples/openfsc_v1_fscinstallation.yaml
    echo "Waiting for the FSCInstallation to become Active (core + gateways registered)..."
    $k wait --for=jsonpath='{.status.phase}'=Active fscinstallation/demo -n fsc-demo --timeout=900s
    echo "Verifying the one-installation-per-namespace guard..."
    $k apply -f - <<'EOF'
    apiVersion: openfsc.fundament.io/v1
    kind: FSCInstallation
    metadata:
      name: conflict
      namespace: fsc-demo
    spec:
      groupID: fsc-demo
      peerID: "11111111111111111111"
      directory:
        mode: Self
      postgres:
        storageClass: local-path
    EOF
    $k wait --for=jsonpath='{.status.phase}'=Error fscinstallation/conflict -n fsc-demo --timeout=120s
    $k delete fscinstallation/conflict -n fsc-demo
    echo "Verifying the conflict deletion left the active installation untouched..."
    $k get deploy fsc-open-fsc-manager -n fsc-demo > /dev/null
    $k wait --for=jsonpath='{.status.phase}'=Active fscinstallation/demo -n fsc-demo --timeout=120s
    $k get fscinstallations -A
    $k -n fsc-demo get pods,deploy

# Remove the sample FSCInstallation and its namespace (the operator's
# finalizer tears down the releases; cert-manager, CloudNativePG and the
# operator stay)
test-cleanup:
    kubectl --context {{ kube_context }} delete fscinstallation/demo -n fsc-demo --ignore-not-found
    kubectl --context {{ kube_context }} delete namespace fsc-demo --ignore-not-found

# Preview the console templates against the running cluster (live CR data via
# kubectl, no Console host needed); prereq: an FSCInstallation exists
console-preview port="4319":
    PORT={{ port }} kube_context={{ kube_context }} bun scripts/console-preview/serve.js

# Built console UI. Source lives in console-ui/ (Vite, vanilla TS); the build
# output here is compiled into the plugin binary via console.go's `go:embed`.
# Regenerated by `bun run build` in console-ui/ (the Dockerfile builds it; locally
# run it or `just openfsc::console-preview`). .gitkeep is committed so
# `go build`/`go test` always find a file to embed even before a UI build.
/console/*
!/console/.gitkeep

# Vite app dependencies
/console-ui/node_modules/
